# Optional highest-priority ProxyAPI/OpenAI provider.
# Native OpenAI-compatible path documented by ProxyAPI:
# https://api.proxyapi.ru/openai/v1
PROXYAPI_OPENAI_API_KEY=""

# Optional ProxyAPI/OpenAI model override. Default:
# gpt-5-nano
PROXYAPI_OPENAI_MODEL=""

# Optional base URL override. Default:
# https://api.proxyapi.ru/openai/v1
PROXYAPI_OPENAI_BASE_URL=""

# GEMINI_API_KEY: Gemini Developer API key from Google AI Studio.
# Keep this key server-side only. Do not expose it in the browser bundle.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional model override. Default:
# gemini-2.5-flash
GEMINI_MODEL=""

# Optional comma-separated Gemini fallback models.
# These use the same Gemini API key and are tried when the primary model hits free-tier limits.
# Default inside the app:
# gemini-2.5-flash-lite,gemini-2.0-flash
GEMINI_FALLBACK_MODELS=""

# Optional Groq backup provider.
# If set, the app will fall back to Groq after Gemini failures/quotas.
GROQ_API_KEY=""

# Optional Groq model override. Default:
# openai/gpt-oss-20b
GROQ_MODEL=""

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints when needed.
APP_URL="MY_APP_URL"

# Browser-safe Supabase Auth config.
# These are public anon/browser values, not service-role secrets.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Optional free CAPTCHA provider for Supabase Auth.
# Use a Cloudflare Turnstile site key here and enable CAPTCHA in Supabase Auth settings.
VITE_TURNSTILE_SITE_KEY=""
